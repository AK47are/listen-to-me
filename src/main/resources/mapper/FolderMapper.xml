<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.github.listen_to_me.mapper.FolderMapper">
    <select id="getFolderListOfUsers" resultType="com.github.listen_to_me.domain.entity.Folder">
        select folder.* from folder
        <where>
            folder.id in
            <foreach collection="sysUserFolders" item="sysUserFolder" open="(" close=")" separator=",">
                #{sysUserFolder.folderId}
            </foreach>
        </where>
    </select>
</mapper>
