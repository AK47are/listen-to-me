<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.github.listen_to_me.mapper.SysTagMapper">

    <select id="selectTagsByAudioIds" resultType="com.github.listen_to_me.domain.vo.AudioTagVO">
        select
        atr.audio_id AS audioId,
        t.name AS tagName
        from audio_tag_relation atr
        INNER join sys_tag t ON atr.tag_id = t.id
        where atr.audio_id IN
        <foreach collection="audioIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
</mapper>
